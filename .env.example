NEXT_PUBLIC_SITE_URL=http://localhost:3000

DATABASE_URL="postgresql://username:password@localhost:5432/ourlittleworld_db_local"

# NextAuth
AUTH_SECRET="your_nextauth_secret_here" # Required for NextAuth
# Realtime chat (Ably)
ABLY_API_KEY="your_ably_api_key_here"
# SMTP (Email Provider)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER="your_email@example.com"
SMTP_PASSWORD="your_app_password_here"
SMTP_FROM="your_email@example.com"

# AI Features
OPENAI_API_KEY="your_openai_api_key_here" # Required for Receipt OCR

# Cloudinary (Image Storage)
CLOUDINARY_CLOUD_NAME="your_cloud_name"
CLOUDINARY_API_KEY="your_api_key"
CLOUDINARY_API_SECRET="your_api_secret"
