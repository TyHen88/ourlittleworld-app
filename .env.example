DATABASE_URL="postgresql://username:password@localhost:5432/ourlittleworld_db_local"
DIRECT_URL="postgresql://username:password@localhost:5432/ourlittleworld_db_local"

# Auth.js
AUTH_URL="http://localhost:3000"
AUTH_SECRET="your_auth_secret_here"
GOOGLE_CLIENT_ID="your_google_oauth_web_client_id"
GOOGLE_CLIENT_SECRET="your_google_oauth_web_client_secret"

# Resend (preferred on Railway and other hosted environments)
RESEND_API_KEY="re_your_api_key_here"
RESEND_FROM="OurLittleWorld <onboarding@resend.dev>"

# Web Push
NEXT_PUBLIC_WEB_PUSH_PUBLIC_KEY="your_public_vapid_key_here"
WEB_PUSH_PUBLIC_KEY="your_public_vapid_key_here"
WEB_PUSH_PRIVATE_KEY="your_private_vapid_key_here"
WEB_PUSH_SUBJECT="mailto:your_email@example.com"
CRON_SECRET="set_a_secret_for_scheduled_trip_reminders"
ENABLE_IN_PROCESS_REMINDER_SCHEDULER="false"
REMINDER_POLLING_INTERVAL_MS=30000
APP_URL="http://localhost:3000"
CAPACITOR_SERVER_URL="http://localhost:3000"

# Realtime chat (Ably)
ABLY_API_KEY="your_ably_api_key_here"

# SMTP (optional fallback for local/testing)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER="your_email@example.com"
SMTP_PASSWORD="your_app_password_here"
SMTP_FROM="your_email@example.com"

# AI Features
OPENAI_API_KEY="your_openai_api_key_here"

# Cloudinary (Image Storage)
CLOUDINARY_CLOUD_NAME="your_cloud_name"
CLOUDINARY_API_KEY="your_api_key"
CLOUDINARY_API_SECRET="your_api_secret"
