generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Payer {
  HIS
  HERS
  SHARED
}

enum TransactionType {
  INCOME
  EXPENSE
}

enum ReminderSource {
  CUSTOM
  TRIP
}

// NextAuth Requirements
model User {
  id                   String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name                 String?
  email                String?   @unique
  emailVerified        DateTime?
  image                String?
  password             String?   // For credentials auth
  is_deleted           Boolean   @default(false)

  // Custom fields from Profile
  full_name            String?
  avatar_url           String?
  bio                  String?   @db.Text

  onboarding_completed Boolean   @default(false)
  user_type            String    @default("COUPLE") // "SINGLE" or "COUPLE"

  couple_id            String?   @db.Uuid
  world_theme          String?   @default("blush")
  world_theme_url      String?
  world_theme_config   Json?

  // Timestamps
  created_at           DateTime  @default(now()) @db.Timestamptz(6)
  updated_at           DateTime  @updatedAt @db.Timestamptz(6)

  // Relations
  accounts             Account[]
  sessions             Session[]
  couple               Couple?       @relation("MemberOf", fields: [couple_id], references: [id], onDelete: SetNull)
  transactions         Transaction[] @relation("CreatedTransactions")
  personalTransactions Transaction[] @relation("UserTransactions")
  posts                Post[]
  dailyMoods           DailyMood[]
  trips                Trip[]
  savingsGoals         SavingsGoal[]
  budgets              Budget[]
  pushSubscriptions    PushSubscription[]
  chatReadStates       ChatReadState[]
  reminders            Reminder[]         @relation("UserReminders")
  createdReminders     Reminder[]         @relation("CreatedReminders")

  @@index([is_deleted])

  @@map("users")
}

model Account {
  id                 String  @id @default(cuid())
  userId             String  @db.Uuid
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?  @db.Text
  access_token       String?  @db.Text
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?  @db.Text
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String   @db.Uuid
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model PushSubscription {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id    String   @db.Uuid
  endpoint   String   @unique @db.Text
  p256dh     String   @db.Text
  auth       String   @db.Text
  user_agent String?  @db.Text
  created_at DateTime @default(now()) @db.Timestamptz(6)
  updated_at DateTime @updatedAt @db.Timestamptz(6)

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id])
  @@map("push_subscriptions")
}

model Couple {
  id                 String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  invite_code        String    @unique
  couple_name        String?
  start_date         DateTime? @db.Date
  couple_photo_url   String?
  partner_1_nickname String?
  partner_2_nickname String?
  world_theme        String?   @default("blush")
  world_theme_url    String?
  world_theme_config Json?

  // Timestamps
  created_at DateTime @default(now()) @db.Timestamptz(6)
  updated_at DateTime @updatedAt @db.Timestamptz(6)

  // Relations
  members      User[]        @relation("MemberOf")
  transactions Transaction[]
  budgets      Budget[]
  posts        Post[]
  dailyMoods   DailyMood[]
  savingsGoals SavingsGoal[]
  trips        Trip[]
  chatReadStates ChatReadState[]
  reminders    Reminder[]

  @@map("couples")
}

model ChatReadState {
  user_id              String    @db.Uuid
  couple_id            String    @db.Uuid
  last_read_post_id    String?   @db.Uuid
  last_read_created_at DateTime? @db.Timestamptz(6)
  created_at           DateTime  @default(now()) @db.Timestamptz(6)
  updated_at           DateTime  @updatedAt @db.Timestamptz(6)

  user   User   @relation(fields: [user_id], references: [id], onDelete: Cascade)
  couple Couple @relation(fields: [couple_id], references: [id], onDelete: Cascade)

  @@id([user_id, couple_id])
  @@index([couple_id])
  @@map("chat_read_states")
}

model Budget {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  couple_id      String?  @db.Uuid
  user_id        String?  @db.Uuid // For solo budget
  month          String   // Format: "2026-02" for February 2026
  monthly_total  Decimal  @db.Decimal(10, 2)
  his_budget     Decimal  @db.Decimal(10, 2)
  hers_budget    Decimal  @db.Decimal(10, 2)
  shared_budget  Decimal  @db.Decimal(10, 2)
  is_active      Boolean  @default(true)

  // Timestamps
  created_at DateTime @default(now()) @db.Timestamptz(6)
  updated_at DateTime @updatedAt @db.Timestamptz(6)

  // Relations
  couple Couple? @relation(fields: [couple_id], references: [id], onDelete: Cascade)
  user   User?   @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([couple_id, month], name: "couple_id_month")
  @@unique([user_id, month], name: "user_id_month")
  @@map("budgets")
}

model Transaction {
  id               String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  couple_id        String?         @db.Uuid
  user_id          String?         @db.Uuid
  amount           Decimal         @db.Decimal(10, 2)
  category         String
  note             String?
  payer            Payer?
  type             TransactionType @default(EXPENSE)
  created_by       String          @db.Uuid
  trip_id          String?         @db.Uuid
  transaction_date DateTime?       @default(now()) @db.Timestamptz(6)

  // Timestamps
  created_at DateTime @default(now()) @db.Timestamptz(6)
  updated_at DateTime @updatedAt @db.Timestamptz(6)

  // Relations
  couple  Couple? @relation(fields: [couple_id], references: [id])
  user    User?   @relation("UserTransactions", fields: [user_id], references: [id])
  creator User    @relation("CreatedTransactions", fields: [created_by], references: [id])
  trip    Trip?   @relation(fields: [trip_id], references: [id], onDelete: SetNull)

  @@map("transactions")
}

model Post {
  id        String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  couple_id String? @db.Uuid
  author_id String  @db.Uuid
  content   String  @db.Text
  image_url String?
  category  String?
  metadata   Json?
  is_deleted Boolean @default(false)

  // Timestamps
  created_at DateTime @default(now()) @db.Timestamptz(6)
  updated_at DateTime @updatedAt @db.Timestamptz(6)

  // Relations
  couple Couple? @relation(fields: [couple_id], references: [id], onDelete: Cascade)
  author User    @relation(fields: [author_id], references: [id], onDelete: Cascade)

  @@index([couple_id])
  @@index([author_id])
  @@index([is_deleted])
  @@index([created_at(sort: Desc)])
  @@map("posts")
}

model DailyMood {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  couple_id  String?  @db.Uuid
  user_id    String   @db.Uuid
  mood_date  DateTime @default(now()) @db.Date
  mood_emoji String
  note       String?
  metadata   Json?

  // Timestamps
  created_at DateTime @default(now()) @db.Timestamptz(6)

  // Relations
  couple Couple? @relation(fields: [couple_id], references: [id], onDelete: Cascade)
  user   User    @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([user_id, mood_date])
  @@map("daily_moods")
}

model SavingsGoal {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  couple_id       String?  @db.Uuid
  user_id         String?  @db.Uuid // For solo goals
  title           String
  description     String?
  target_amount   Decimal  @db.Decimal(10, 2)
  current_amount  Decimal  @default(0) @db.Decimal(10, 2)
  icon            String?  @default("Target")
  color           String?  @default("purple")
  deadline        DateTime? @db.Date
  priority        String?  @default("medium") // low, medium, high
  is_completed    Boolean  @default(false)
  completed_at    DateTime? @db.Timestamptz(6)
  metadata        Json?    // For storing additional data like milestones, notes, etc.

  // Timestamps
  created_at DateTime @default(now()) @db.Timestamptz(6)
  updated_at DateTime @updatedAt @db.Timestamptz(6)

  // Relations
  couple Couple? @relation(fields: [couple_id], references: [id], onDelete: Cascade)
  user   User?   @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@map("savings_goals")
}

model Trip {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  couple_id       String?  @db.Uuid
  user_id         String?  @db.Uuid
  title           String
  destination     String
  start_date      DateTime @db.Timestamptz(6)
  end_date        DateTime @db.Timestamptz(6)
  status          String   @default("PLANNED") // "PLANNED", "ONGOING", "COMPLETED"
  budget          Decimal? @db.Decimal(10, 2)
  image_url       String?
  notes           String?  @db.Text
  metadata        Json?

  // Timestamps
  created_at DateTime @default(now()) @db.Timestamptz(6)
  updated_at DateTime @updatedAt @db.Timestamptz(6)

  // Relations
  couple        Couple?       @relation(fields: [couple_id], references: [id], onDelete: Cascade)
  user          User?         @relation(fields: [user_id], references: [id], onDelete: Cascade)
  transactions  Transaction[]
  reminder      Reminder?

  @@index([couple_id])
  @@index([user_id])
  @@map("trips")
}

model Reminder {
  id                   String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  couple_id            String?        @db.Uuid
  user_id              String?        @db.Uuid
  trip_id              String?        @unique @db.Uuid
  created_by           String         @db.Uuid
  source               ReminderSource @default(CUSTOM)
  name                 String
  note                 String?        @db.Text
  reminder_date_key    String?        @db.VarChar(10)
  reminder_time        String?        @db.VarChar(5)
  has_date             Boolean        @default(false)
  has_time             Boolean        @default(false)
  scheduled_for        DateTime?      @db.Timestamptz(6)
  is_completed         Boolean        @default(false)
  is_deleted           Boolean        @default(false)
  completed_at         DateTime?      @db.Timestamptz(6)
  notification_sent_at DateTime?      @db.Timestamptz(6)
  created_at           DateTime       @default(now()) @db.Timestamptz(6)
  updated_at           DateTime       @updatedAt @db.Timestamptz(6)

  couple  Couple? @relation(fields: [couple_id], references: [id], onDelete: Cascade)
  user    User?   @relation("UserReminders", fields: [user_id], references: [id], onDelete: Cascade)
  trip    Trip?   @relation(fields: [trip_id], references: [id], onDelete: Cascade)
  creator User    @relation("CreatedReminders", fields: [created_by], references: [id], onDelete: Cascade)

  @@index([couple_id])
  @@index([user_id])
  @@index([created_by])
  @@index([reminder_date_key])
  @@index([scheduled_for])
  @@index([is_deleted])
  @@index([is_completed, scheduled_for])
  @@map("reminders")
}
