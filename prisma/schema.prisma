generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Payer {
  HIS
  HERS
  SHARED
}

enum TransactionType {
  INCOME
  EXPENSE
}

enum GoalType {
  SAVINGS
  LEARNING
  WEDDING
  FUTURE_SELF
  SOCIAL_CONTRACT
  LONG_TERM_CHANGE
}

enum GoalCadence {
  YEAR
  MONTH
  DAY
}

enum GoalMilestoneStatus {
  PENDING
  COMPLETED
  SKIPPED
}

enum ReminderSourceType {
  GOAL_MILESTONE
  GOAL
  BUDGET_ALERT
  DAILY_DIGEST
}

enum ReminderTriggerType {
  GOAL_UPCOMING
  GOAL_DUE
  GOAL_OVERDUE
  DAILY_DIGEST
  BUDGET_WARNING
  BUDGET_OVER
  CATEGORY_SPIKE
  NO_EXPENSE_LOG
}

enum ReminderStatus {
  PENDING
  PARTIAL
  DELIVERED
  FAILED
  DISMISSED
}

enum ReminderChannel {
  EMAIL
  TELEGRAM
}

enum ReminderDeliveryStatus {
  PENDING
  SENT
  FAILED
  SKIPPED
}

// NextAuth Requirements
model User {
  id                   String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name                 String?
  email                String?   @unique
  emailVerified        DateTime?
  image                String?
  password             String?   // For credentials auth
  is_deleted           Boolean   @default(false)

  // Custom fields from Profile
  full_name            String?
  avatar_url           String?

  onboarding_completed Boolean   @default(false)
  user_type            String    @default("COUPLE") // "SINGLE" or "COUPLE"

  couple_id            String?   @db.Uuid

  // Timestamps
  created_at           DateTime  @default(now()) @db.Timestamptz(6)
  updated_at           DateTime  @updatedAt @db.Timestamptz(6)

  // Relations
  accounts             Account[]
  sessions             Session[]
  couple               Couple?       @relation("MemberOf", fields: [couple_id], references: [id], onDelete: SetNull)
  transactions         Transaction[] @relation("CreatedTransactions")
  personalTransactions Transaction[] @relation("UserTransactions")
  posts                Post[]
  dailyMoods           DailyMood[]
  trips                Trip[]
  savingsGoals         SavingsGoal[]
  budgets              Budget[]
  notificationPreference NotificationPreference?
  reminders            Reminder[]

  @@index([is_deleted])

  @@map("users")
}

model Account {
  id                 String  @id @default(cuid())
  userId             String  @db.Uuid
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?  @db.Text
  access_token       String?  @db.Text
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?  @db.Text
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String   @db.Uuid
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model Couple {
  id                 String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  invite_code        String    @unique
  couple_name        String?
  start_date         DateTime? @db.Date
  couple_photo_url   String?
  partner_1_nickname String?
  partner_2_nickname String?
  world_theme        String?   @default("blush")

  // Timestamps
  created_at DateTime @default(now()) @db.Timestamptz(6)
  updated_at DateTime @updatedAt @db.Timestamptz(6)

  // Relations
  members      User[]        @relation("MemberOf")
  transactions Transaction[]
  budgets      Budget[]
  posts        Post[]
  dailyMoods   DailyMood[]
  savingsGoals SavingsGoal[]
  trips        Trip[]

  @@map("couples")
}

model Budget {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  couple_id      String?  @db.Uuid
  user_id        String?  @db.Uuid // For solo budget
  month          String   // Format: "2026-02" for February 2026
  monthly_total  Decimal  @db.Decimal(10, 2)
  his_budget     Decimal  @db.Decimal(10, 2)
  hers_budget    Decimal  @db.Decimal(10, 2)
  shared_budget  Decimal  @db.Decimal(10, 2)
  is_active      Boolean  @default(true)

  // Timestamps
  created_at DateTime @default(now()) @db.Timestamptz(6)
  updated_at DateTime @updatedAt @db.Timestamptz(6)

  // Relations
  couple Couple? @relation(fields: [couple_id], references: [id], onDelete: Cascade)
  user   User?   @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([couple_id, month], name: "couple_id_month")
  @@unique([user_id, month], name: "user_id_month")
  @@map("budgets")
}

model Transaction {
  id               String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  couple_id        String?         @db.Uuid
  user_id          String?         @db.Uuid
  amount           Decimal         @db.Decimal(10, 2)
  category         String
  note             String?
  payer            Payer?
  type             TransactionType @default(EXPENSE)
  created_by       String          @db.Uuid
  trip_id          String?         @db.Uuid
  transaction_date DateTime?       @default(now()) @db.Timestamptz(6)

  // Timestamps
  created_at DateTime @default(now()) @db.Timestamptz(6)
  updated_at DateTime @updatedAt @db.Timestamptz(6)

  // Relations
  couple  Couple? @relation(fields: [couple_id], references: [id])
  user    User?   @relation("UserTransactions", fields: [user_id], references: [id])
  creator User    @relation("CreatedTransactions", fields: [created_by], references: [id])
  trip    Trip?   @relation(fields: [trip_id], references: [id], onDelete: SetNull)

  @@map("transactions")
}

model Post {
  id        String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  couple_id String? @db.Uuid
  author_id String  @db.Uuid
  content   String  @db.Text
  image_url String?
  category  String?
  metadata   Json?
  is_deleted Boolean @default(false)

  // Timestamps
  created_at DateTime @default(now()) @db.Timestamptz(6)
  updated_at DateTime @updatedAt @db.Timestamptz(6)

  // Relations
  couple Couple? @relation(fields: [couple_id], references: [id], onDelete: Cascade)
  author User    @relation(fields: [author_id], references: [id], onDelete: Cascade)

  @@index([couple_id])
  @@index([author_id])
  @@index([is_deleted])
  @@index([created_at(sort: Desc)])
  @@map("posts")
}

model DailyMood {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  couple_id  String?  @db.Uuid
  user_id    String   @db.Uuid
  mood_date  DateTime @default(now()) @db.Date
  mood_emoji String
  note       String?
  metadata   Json?

  // Timestamps
  created_at DateTime @default(now()) @db.Timestamptz(6)

  // Relations
  couple Couple? @relation(fields: [couple_id], references: [id], onDelete: Cascade)
  user   User    @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([user_id, mood_date])
  @@map("daily_moods")
}

model SavingsGoal {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  couple_id       String?  @db.Uuid
  user_id         String?  @db.Uuid // For solo goals
  title           String
  description     String?
  target_amount   Decimal  @db.Decimal(10, 2)
  current_amount  Decimal  @default(0) @db.Decimal(10, 2)
  icon            String?  @default("Target")
  color           String?  @default("purple")
  deadline        DateTime? @db.Date
  reminder_at     DateTime? @db.Timestamptz(6)
  priority        String?  @default("medium") // low, medium, high
  type            GoalType @default(SAVINGS)
  is_completed    Boolean  @default(false)
  completed_at    DateTime? @db.Timestamptz(6)
  metadata        Json?    // For storing additional data like milestones, notes, etc.
  profile         Json?

  // Timestamps
  created_at DateTime @default(now()) @db.Timestamptz(6)
  updated_at DateTime @updatedAt @db.Timestamptz(6)

  // Relations
  couple     Couple?         @relation(fields: [couple_id], references: [id], onDelete: Cascade)
  user       User?           @relation(fields: [user_id], references: [id], onDelete: Cascade)
  milestones GoalMilestone[]

  @@map("savings_goals")
}

model GoalMilestone {
  id              String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  goal_id         String              @db.Uuid
  title           String
  description     String?
  cadence         GoalCadence
  due_at          DateTime?           @db.Timestamptz(6)
  status          GoalMilestoneStatus @default(PENDING)
  order_index     Int                 @default(0)
  is_required     Boolean             @default(true)
  completed_at    DateTime?           @db.Timestamptz(6)
  reminder_offset_minutes Int?        @default(1440)
  metadata        Json?
  created_at      DateTime            @default(now()) @db.Timestamptz(6)
  updated_at      DateTime            @updatedAt @db.Timestamptz(6)

  goal            SavingsGoal         @relation(fields: [goal_id], references: [id], onDelete: Cascade)
  reminders       Reminder[]

  @@index([goal_id, due_at])
  @@map("goal_milestones")
}

model NotificationPreference {
  id                    String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id               String   @unique @db.Uuid
  email_enabled         Boolean  @default(true)
  telegram_enabled      Boolean  @default(false)
  budget_alerts_enabled Boolean  @default(true)
  daily_digest_enabled  Boolean  @default(true)
  tracking_nudges_enabled Boolean @default(false)
  quiet_hours_enabled   Boolean  @default(false)
  quiet_hours_start     Int?
  quiet_hours_end       Int?
  timezone              String   @default("UTC")
  digest_hour           Int      @default(20)
  email_address         String?
  telegram_chat_id      String?
  telegram_verified     Boolean  @default(false)
  telegram_bound_at     DateTime? @db.Timestamptz(6)
  created_at            DateTime @default(now()) @db.Timestamptz(6)
  updated_at            DateTime @updatedAt @db.Timestamptz(6)

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@map("notification_preferences")
}

model Reminder {
  id               String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  owner_user_id    String             @db.Uuid
  milestone_id     String?            @db.Uuid
  source_type      ReminderSourceType
  trigger_type     ReminderTriggerType
  source_ref       String?
  dedupe_key       String?            @unique
  title            String
  body             String             @db.Text
  analysis_summary String?
  facts            Json?
  status           ReminderStatus     @default(PENDING)
  due_at           DateTime           @db.Timestamptz(6)
  delivered_at     DateTime?          @db.Timestamptz(6)
  acknowledged_at  DateTime?          @db.Timestamptz(6)
  dismissed_at     DateTime?          @db.Timestamptz(6)
  metadata         Json?
  created_at       DateTime           @default(now()) @db.Timestamptz(6)
  updated_at       DateTime           @updatedAt @db.Timestamptz(6)

  owner      User           @relation(fields: [owner_user_id], references: [id], onDelete: Cascade)
  milestone  GoalMilestone? @relation(fields: [milestone_id], references: [id], onDelete: SetNull)
  deliveries ReminderDelivery[]

  @@index([owner_user_id, due_at])
  @@index([status, due_at])
  @@map("reminders")
}

model ReminderDelivery {
  id               String                 @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  reminder_id      String                 @db.Uuid
  channel          ReminderChannel
  status           ReminderDeliveryStatus @default(PENDING)
  attempt_count    Int                    @default(1)
  error_message    String?
  provider_response Json?
  sent_at          DateTime?              @db.Timestamptz(6)
  failed_at        DateTime?              @db.Timestamptz(6)
  created_at       DateTime               @default(now()) @db.Timestamptz(6)
  updated_at       DateTime               @updatedAt @db.Timestamptz(6)

  reminder Reminder @relation(fields: [reminder_id], references: [id], onDelete: Cascade)

  @@index([reminder_id, channel])
  @@map("reminder_deliveries")
}

model Trip {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  couple_id       String?  @db.Uuid
  user_id         String?  @db.Uuid
  title           String
  destination     String
  start_date      DateTime @db.Timestamptz(6)
  end_date        DateTime @db.Timestamptz(6)
  status          String   @default("PLANNED") // "PLANNED", "ONGOING", "COMPLETED"
  budget          Decimal? @db.Decimal(10, 2)
  image_url       String?
  notes           String?  @db.Text
  metadata        Json?

  // Timestamps
  created_at DateTime @default(now()) @db.Timestamptz(6)
  updated_at DateTime @updatedAt @db.Timestamptz(6)

  // Relations
  couple        Couple?       @relation(fields: [couple_id], references: [id], onDelete: Cascade)
  user          User?         @relation(fields: [user_id], references: [id], onDelete: Cascade)
  transactions  Transaction[]

  @@index([couple_id])
  @@index([user_id])
  @@map("trips")
}
