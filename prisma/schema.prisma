generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Payer {
  HIS
  HERS
  SHARED
}

enum TransactionType {
  INCOME
  EXPENSE
}

// NextAuth Requirements
model User {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  password      String?   // For credentials auth

  // Custom fields from Profile
  full_name     String?
  avatar_url    String?
  couple_id     String?   @db.Uuid

  // Timestamps
  created_at    DateTime  @default(now()) @db.Timestamptz(6)
  updated_at    DateTime  @updatedAt @db.Timestamptz(6)

  // Relations
  accounts     Account[]
  sessions     Session[]
  couple       Couple?       @relation("MemberOf", fields: [couple_id], references: [id], onDelete: SetNull)
  transactions Transaction[]
  posts        Post[]
  dailyMoods   DailyMood[]

  @@map("users")
}

model Account {
  id                 String  @id @default(cuid())
  userId             String  @db.Uuid
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?  @db.Text
  access_token       String?  @db.Text
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?  @db.Text
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String   @db.Uuid
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model Couple {
  id                 String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  invite_code        String    @unique
  couple_name        String?
  start_date         DateTime? @db.Date
  couple_photo_url   String?
  partner_1_nickname String?
  partner_2_nickname String?
  world_theme        String?   @default("blush")

  // Timestamps
  created_at DateTime @default(now()) @db.Timestamptz(6)
  updated_at DateTime @updatedAt @db.Timestamptz(6)

  // Relations
  members      User[]        @relation("MemberOf")
  transactions Transaction[]
  budgets      Budget[]
  posts        Post[]
  dailyMoods   DailyMood[]
  savingsGoals SavingsGoal[]

  @@map("couples")
}

model Budget {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  couple_id      String   @db.Uuid
  month          String   // Format: "2026-02" for February 2026
  monthly_total  Decimal  @db.Decimal(10, 2)
  his_budget     Decimal  @db.Decimal(10, 2)
  hers_budget    Decimal  @db.Decimal(10, 2)
  shared_budget  Decimal  @db.Decimal(10, 2)
  is_active      Boolean  @default(true)

  // Timestamps
  created_at DateTime @default(now()) @db.Timestamptz(6)
  updated_at DateTime @updatedAt @db.Timestamptz(6)

  // Relations
  couple Couple @relation(fields: [couple_id], references: [id], onDelete: Cascade)

  @@unique([couple_id, month])
  @@map("budgets")
}

model Transaction {
  id               String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  couple_id        String          @db.Uuid
  amount           Decimal         @db.Decimal(10, 2)
  category         String
  note             String?
  payer            Payer?
  type             TransactionType @default(EXPENSE)
  created_by       String          @db.Uuid
  transaction_date DateTime?       @default(now()) @db.Timestamptz(6)

  // Timestamps
  created_at DateTime @default(now()) @db.Timestamptz(6)
  updated_at DateTime @updatedAt @db.Timestamptz(6)

  // Relations
  couple  Couple @relation(fields: [couple_id], references: [id], onDelete: Cascade)
  creator User   @relation(fields: [created_by], references: [id], onDelete: Cascade)

  @@map("transactions")
}

model Post {
  id        String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  couple_id String  @db.Uuid
  author_id String  @db.Uuid
  content   String  @db.Text
  image_url String?
  category  String?
  metadata   Json?
  is_deleted Boolean @default(false)

  // Timestamps
  created_at DateTime @default(now()) @db.Timestamptz(6)
  updated_at DateTime @updatedAt @db.Timestamptz(6)

  // Relations
  couple Couple @relation(fields: [couple_id], references: [id], onDelete: Cascade)
  author User   @relation(fields: [author_id], references: [id], onDelete: Cascade)

  @@map("posts")
}

model DailyMood {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  couple_id  String   @db.Uuid
  user_id    String   @db.Uuid
  mood_date  DateTime @default(now()) @db.Date
  mood_emoji String
  note       String?
  metadata   Json?

  // Timestamps
  created_at DateTime @default(now()) @db.Timestamptz(6)

  // Relations
  couple Couple @relation(fields: [couple_id], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([user_id, mood_date])
  @@map("daily_moods")
}

model SavingsGoal {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  couple_id       String   @db.Uuid
  title           String
  description     String?
  target_amount   Decimal  @db.Decimal(10, 2)
  current_amount  Decimal  @default(0) @db.Decimal(10, 2)
  icon            String?  @default("Target")
  color           String?  @default("purple")
  deadline        DateTime? @db.Date
  priority        String?  @default("medium") // low, medium, high
  is_completed    Boolean  @default(false)
  completed_at    DateTime? @db.Timestamptz(6)
  metadata        Json?    // For storing additional data like milestones, notes, etc.

  // Timestamps
  created_at DateTime @default(now()) @db.Timestamptz(6)
  updated_at DateTime @updatedAt @db.Timestamptz(6)

  // Relations
  couple Couple @relation(fields: [couple_id], references: [id], onDelete: Cascade)

  @@map("savings_goals")
}
